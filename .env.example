# GitLab Configuration (REQUIRED)
GITLAB_TOKEN=your-gitlab-personal-access-token

# GitLab Server (optional, defaults to https://gitlab.example.com)
GITLAB_URL=https://gitlab.example.com

# SSL Verification (optional, defaults to true)
GITLAB_VERIFY_SSL=true

# Agent Model (optional, defaults to ollama:gpt-4o)
GITLAB_AGENT_MODEL=ollama:gpt-4o

# Ollama Base URL (optional, defaults to http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Allow Repository Writes (optional, defaults to false for safety)
GITLAB_ALLOW_WRITES=false

# Compact Results (optional, defaults to true)
GITLAB_COMPACT_RESULTS=true

# Server Port (optional, defaults to 8000)
PORT=8000
